#!/usr/bin/env bash
set -euo pipefail

module purge
module load anaconda/3

if command -v apptainer >/dev/null 2>&1; then
  container_runtime="apptainer"
elif command -v singularity >/dev/null 2>&1; then
  container_runtime="singularity"
else
  echo "Neither apptainer nor singularity is available in PATH." >&2
  exit 1
fi

IMAGE="/gpfs/software/galaxy/galaxy-rockylinux-9.6.sif"
START_GALAXY_SCRIPT="<%= session.staged_root.join("start-galaxy.sh") %>"

# Admin-managed shared Galaxy tool locations. These defaults live in this repo
# so the shared-tool layout can be managed centrally for all users.
SHARED_GALAXY_ROOT="/gpfs/software/galaxy"
SHARED_GALAXY_CONFIG_ROOT="${SHARED_GALAXY_ROOT}/config"
SHARED_GALAXY_TOOLS_ROOT="${SHARED_GALAXY_ROOT}/tools"
SHARED_GALAXY_SHED_TOOLS_ROOT="${SHARED_GALAXY_ROOT}/shed_tools"
SHARED_GALAXY_TOOL_DATA_ROOT="${SHARED_GALAXY_ROOT}/tool-data"
SHARED_GALAXY_CONDA_ROOT="${SHARED_GALAXY_ROOT}/conda"
ANACONDA_ROOT="/gpfs/software/Anaconda"
BIND_ARGS=()

if [[ ! -f "${IMAGE}" ]]; then
  echo "Galaxy container image not found: ${IMAGE}" >&2
  exit 1
fi
if [[ ! -d "${SHARED_GALAXY_CONFIG_ROOT}" ]]; then
  echo "Shared Galaxy config directory not found: ${SHARED_GALAXY_CONFIG_ROOT}" >&2
  exit 1
fi
if [[ ! -d "${SHARED_GALAXY_TOOLS_ROOT}" ]]; then
  echo "Shared Galaxy tools directory not found: ${SHARED_GALAXY_TOOLS_ROOT}" >&2
  exit 1
fi
if [[ ! -d "${SHARED_GALAXY_SHED_TOOLS_ROOT}" ]]; then
  echo "Shared Galaxy shed tools directory not found: ${SHARED_GALAXY_SHED_TOOLS_ROOT}" >&2
  exit 1
fi
if [[ ! -d "${SHARED_GALAXY_TOOL_DATA_ROOT}" ]]; then
  echo "Shared Galaxy tool-data directory not found: ${SHARED_GALAXY_TOOL_DATA_ROOT}" >&2
  exit 1
fi
if [[ ! -x "${ANACONDA_ROOT}/bin/conda" ]]; then
  echo "Anaconda conda executable not found: ${ANACONDA_ROOT}/bin/conda" >&2
  exit 1
fi
if [[ ! -d "${SHARED_GALAXY_CONDA_ROOT}" ]]; then
  echo "Shared Galaxy conda directory not found: ${SHARED_GALAXY_CONDA_ROOT}" >&2
  exit 1
fi

if [[ -n "<%= context.galaxy_data_dir.to_s.strip %>" ]]; then
  GALAXY_HOST_ROOT="<%= context.galaxy_data_dir.to_s.strip %>"
else
  GALAXY_HOST_ROOT="${HOME}/ondemand/data/galaxy"
fi

HOST_HOME="${HOME}"
GALAXY_FILE_SOURCE_SELECTION="<%= context.galaxy_extra_file_sources.to_s.strip %>"
OOD_MEMORY_REQUEST="<%= context.custom_mem.to_s.strip %>"
USER_SCRATCH_ROOT="/gpfs/scratch/${USER}"
GALAXY_TMPDIR="${USER_SCRATCH_ROOT}/galaxy/tmp"
GALAXY_ACCOUNT_EMAIL="<%= context.galaxy_email.to_s.strip %>"
GALAXY_ACCOUNT_PASSWORD="<%= context.galaxy_password.to_s %>"
GALAXY_CREDENTIALS_FILE="${GALAXY_HOST_ROOT}/credentials.txt"

mkdir -p "${GALAXY_HOST_ROOT}"
mkdir -p "${GALAXY_TMPDIR}"

if [[ -z "${GALAXY_ACCOUNT_EMAIL}" ]]; then
  echo "Galaxy Email Address is required." >&2
  exit 1
fi

if [[ ! -f "${GALAXY_CREDENTIALS_FILE}" ]]; then
  if [[ -z "${GALAXY_ACCOUNT_PASSWORD}" ]]; then
    GALAXY_ACCOUNT_PASSWORD="$(
      python3 -c 'import secrets, string; alphabet = string.ascii_letters + string.digits; print("".join(secrets.choice(alphabet) for _ in range(24)))'
    )"
  fi

  umask 077
  cat > "${GALAXY_CREDENTIALS_FILE}" <<EOF
email=${GALAXY_ACCOUNT_EMAIL}
password=${GALAXY_ACCOUNT_PASSWORD}
EOF
fi

memory_value="${OOD_MEMORY_REQUEST^^}"
memory_value="${memory_value//[[:space:]]/}"
if [[ "${memory_value}" =~ ^([0-9]+)(G|GB)$ ]]; then
  GALAXY_MEMORY_MB="$(( ${BASH_REMATCH[1]} * 1024 ))"
elif [[ "${memory_value}" =~ ^([0-9]+)(M|MB)$ ]]; then
  GALAXY_MEMORY_MB="${BASH_REMATCH[1]}"
else
  echo "Unsupported Memory format: ${OOD_MEMORY_REQUEST}. Use whole-number values such as 4G or 16000M." >&2
  exit 1
fi

cat > "${START_GALAXY_SCRIPT}" <<'EOF'
#!/bin/sh
set -eu

export GALAXY_ROOT=/opt/galaxy
export GALAXY_ROOT_DIR="${GALAXY_ROOT_DIR:-/opt/galaxy}"
export GALAXY_PYTHON="${GALAXY_PYTHON:-/usr/bin/python3}"
export GALAXY_RUNTIME_ROOT="${GALAXY_RUNTIME_ROOT:-/tmp/galaxy}"
export GALAXY_VIRTUAL_ENV="${GALAXY_VIRTUAL_ENV:-/opt/galaxy/.venv}"
export GALAXY_CONFIG_FILE="${GALAXY_CONFIG_FILE:-$GALAXY_RUNTIME_ROOT/config/galaxy.yml}"
export GALAXY_JOB_CONFIG_FILE="${GALAXY_JOB_CONFIG_FILE:-$GALAXY_RUNTIME_ROOT/config/job_conf.xml}"
export GALAXY_LOG_DIR="${GALAXY_LOG_DIR:-$GALAXY_RUNTIME_ROOT/log}"
export GALAXY_PID_DIR="${GALAXY_PID_DIR:-$GALAXY_RUNTIME_ROOT/pids}"
export GALAXY_GRAVITY_STATE_DIR="${GALAXY_GRAVITY_STATE_DIR:-$GALAXY_RUNTIME_ROOT/data/gravity}"
export GALAXY_SHED_TOOL_PATH="${GALAXY_SHED_TOOL_PATH:-$GALAXY_RUNTIME_ROOT/data/shed_tools}"
export GALAXY_TOOL_CONFIG_FILE="${GALAXY_TOOL_CONFIG_FILE:-$GALAXY_RUNTIME_ROOT/config/tool_conf.xml,/opt/galaxy/config/tool_conf.xml.sample}"
export GALAXY_SHED_TOOL_CONFIG_FILE="${GALAXY_SHED_TOOL_CONFIG_FILE:-$GALAXY_RUNTIME_ROOT/config/shed_tool_conf.xml}"
export GALAXY_TOOL_DATA_PATH="${GALAXY_TOOL_DATA_PATH:-$GALAXY_RUNTIME_ROOT/data/tool_data}"
export GALAXY_FILE_SOURCES_CONFIG_FILE="${GALAXY_FILE_SOURCES_CONFIG_FILE:-$GALAXY_RUNTIME_ROOT/config/file_sources_conf.yml}"
export GALAXY_USER_LIBRARY_IMPORT_DIR="${GALAXY_USER_LIBRARY_IMPORT_DIR:-$HOME}"
export GALAXY_ALLOW_PATH_PASTE="${GALAXY_ALLOW_PATH_PASTE:-false}"
export GALAXY_ID_SECRET_FILE="${GALAXY_ID_SECRET_FILE:-/srv/galaxy/config/id_secret}"
export GALAXY_TOOL_SHEDS_CONFIG_FILE="${GALAXY_TOOL_SHEDS_CONFIG_FILE:-/opt/galaxy/config/tool_sheds_conf.xml.sample}"
export GALAXY_DEPENDENCY_RESOLVERS_CONFIG_FILE="${GALAXY_DEPENDENCY_RESOLVERS_CONFIG_FILE:-}"
export GALAXY_CONDA_PREFIX="${GALAXY_CONDA_PREFIX:-$GALAXY_RUNTIME_ROOT/conda}"
export GALAXY_CONDA_AUTO_INIT="${GALAXY_CONDA_AUTO_INIT:-false}"
export GALAXY_CONDA_AUTO_INSTALL="${GALAXY_CONDA_AUTO_INSTALL:-false}"
export GALAXY_CONDA_EXEC="${GALAXY_CONDA_EXEC:-}"
export GALAXY_ENABLE_SCRATCH_FILE_SOURCE="${GALAXY_ENABLE_SCRATCH_FILE_SOURCE:-false}"
export GALAXY_ENABLE_PROJECTS_FILE_SOURCE="${GALAXY_ENABLE_PROJECTS_FILE_SOURCE:-false}"
export GALAXY_CONFIG_HOST="${GALAXY_CONFIG_HOST:-0.0.0.0}"
export GALAXY_CONFIG_PORT="${GALAXY_CONFIG_PORT:-8080}"
export GALAXY_URL_PREFIX="${GALAXY_URL_PREFIX:-/}"
export GALAXY_SKIP_CLIENT_BUILD="${GALAXY_SKIP_CLIENT_BUILD:-1}"
export GALAXY_ADMIN_USERS="${GALAXY_ADMIN_USERS:-}"
export GALAXY_SMTP_SERVER="${GALAXY_SMTP_SERVER:-}"
export GALAXY_SMTP_USERNAME="${GALAXY_SMTP_USERNAME:-}"
export GALAXY_SMTP_PASSWORD="${GALAXY_SMTP_PASSWORD:-}"
export GALAXY_SMTP_SSL="${GALAXY_SMTP_SSL:-false}"
export GALAXY_EMAIL_FROM="${GALAXY_EMAIL_FROM:-}"
export GALAXY_ERROR_EMAIL_TO="${GALAXY_ERROR_EMAIL_TO:-}"
export GALAXY_SLOTS="${GALAXY_SLOTS:-1}"
export GALAXY_MEMORY_MB="${GALAXY_MEMORY_MB:-1024}"
export TMPDIR="${TMPDIR:-$GALAXY_RUNTIME_ROOT/data/tmp}"

mkdir -p \
    "$GALAXY_RUNTIME_ROOT/config" \
    "$GALAXY_RUNTIME_ROOT/data/files" \
    "$GALAXY_RUNTIME_ROOT/data/tmp" \
    "$GALAXY_RUNTIME_ROOT/data/job_working_directory" \
    "$GALAXY_RUNTIME_ROOT/data/tool_dependencies" \
    "$GALAXY_GRAVITY_STATE_DIR" \
    "$GALAXY_GRAVITY_STATE_DIR/log" \
    "$GALAXY_RUNTIME_ROOT/log" \
    "$GALAXY_RUNTIME_ROOT/pids"

mkdir -p \
    "$GALAXY_TOOL_DATA_PATH" \
    "$GALAXY_SHED_TOOL_PATH"

export GIT_CONFIG_COUNT=1
export GIT_CONFIG_KEY_0=safe.directory
export GIT_CONFIG_VALUE_0="$GALAXY_ROOT"

rm -f "$GALAXY_RUNTIME_ROOT"/pids/*.pid

if [ ! -f "$GALAXY_SHED_TOOL_CONFIG_FILE" ]; then
    cat >"$GALAXY_SHED_TOOL_CONFIG_FILE" <<EOF_INNER
<?xml version="1.0"?>
<toolbox tool_path="${GALAXY_SHED_TOOL_PATH}">
</toolbox>
EOF_INNER
fi

GALAXY_PRIMARY_TOOL_CONFIG_FILE=$(printf '%s' "$GALAXY_TOOL_CONFIG_FILE" | cut -d, -f1)
if [ ! -f "$GALAXY_PRIMARY_TOOL_CONFIG_FILE" ]; then
    mkdir -p "$(dirname "$GALAXY_PRIMARY_TOOL_CONFIG_FILE")"
    cat >"$GALAXY_PRIMARY_TOOL_CONFIG_FILE" <<EOF_INNER
<?xml version="1.0"?>
<toolbox monitor="true">
</toolbox>
EOF_INNER
fi

mkdir -p "$(dirname "$GALAXY_FILE_SOURCES_CONFIG_FILE")"
cat >"$GALAXY_FILE_SOURCES_CONFIG_FILE" <<EOF_INNER
- id: seawulf_home
  label: Home
  doc: SeaWulf home directory
  type: posix
  root: "$HOME"
  writable: false
EOF_INNER

if [ "$GALAXY_ENABLE_SCRATCH_FILE_SOURCE" = "true" ]; then
    cat >>"$GALAXY_FILE_SOURCES_CONFIG_FILE" <<EOF_INNER
- id: seawulf_scratch
  label: Scratch
  doc: SeaWulf scratch directory
  type: posix
  root: "/gpfs/scratch/$USER"
  writable: false
EOF_INNER
fi

if [ "$GALAXY_ENABLE_PROJECTS_FILE_SOURCE" = "true" ]; then
    if [ -d /gpfs/projects ]; then
        for project_dir in /gpfs/projects/*; do
            [ -d "$project_dir" ] || continue
            [ -r "$project_dir" ] || continue
            [ -x "$project_dir" ] || continue

            project_name=$(basename "$project_dir")
            project_id=$(printf '%s' "$project_name" | tr -c '[:alnum:]' '_')

            cat >>"$GALAXY_FILE_SOURCES_CONFIG_FILE" <<EOF_INNER
- id: seawulf_project_${project_id}
  label: "Project: ${project_name}"
  doc: "SeaWulf project directory"
  type: "posix"
  root: "${project_dir}"
  writable: false
EOF_INNER
        done
    fi
fi

cat >"$GALAXY_JOB_CONFIG_FILE" <<EOF_INNER
<?xml version="1.0"?>
<job_conf>
    <plugins>
        <plugin id="local" type="runner" load="galaxy.jobs.runners.local:LocalJobRunner" workers="4" />
    </plugins>
    <handlers>
        <handler id="main" />
    </handlers>
    <destinations default="local">
        <destination id="local" runner="local">
            <env id="GALAXY_SLOTS">${GALAXY_SLOTS}</env>
            <env id="GALAXY_MEMORY_MB">${GALAXY_MEMORY_MB}</env>
            <env id="TMPDIR">${TMPDIR}</env>
        </destination>
    </destinations>
</job_conf>
EOF_INNER

if [ ! -r "$GALAXY_ID_SECRET_FILE" ]; then
    echo "Galaxy id_secret file not found or not readable: $GALAXY_ID_SECRET_FILE" >&2
    exit 1
fi

GALAXY_ID_SECRET=$(tr -d '\r\n' <"$GALAXY_ID_SECRET_FILE")
if [ -z "$GALAXY_ID_SECRET" ]; then
    echo "Galaxy id_secret file is empty: $GALAXY_ID_SECRET_FILE" >&2
    exit 1
fi
GALAXY_ID_SECRET_LENGTH=$(printf '%s' "$GALAXY_ID_SECRET" | wc -c | tr -d ' ')
if [ "$GALAXY_ID_SECRET_LENGTH" -gt 56 ]; then
    echo "Galaxy id_secret is too long (${GALAXY_ID_SECRET_LENGTH} bytes). Galaxy requires 4-56 bytes." >&2
    exit 1
fi

cat >"$GALAXY_CONFIG_FILE" <<EOF_INNER
galaxy:
  brand: "Galaxy"
  admin_users: "${GALAXY_ADMIN_USERS}"
  allow_local_account_creation: true
  user_activation_on: false
  id_secret: "${GALAXY_ID_SECRET}"
  root: "${GALAXY_ROOT_DIR}"
  galaxy_url_prefix: "${GALAXY_URL_PREFIX}"
  data_dir: "${GALAXY_RUNTIME_ROOT}/data"
  host: "${GALAXY_CONFIG_HOST}"
  port: ${GALAXY_CONFIG_PORT}
  job_config_file: "${GALAXY_JOB_CONFIG_FILE}"
  database_connection: "sqlite:///${GALAXY_RUNTIME_ROOT}/data/galaxy.sqlite?isolation_level=IMMEDIATE"
  file_path: "${GALAXY_RUNTIME_ROOT}/data/files"
  new_file_path: "${GALAXY_RUNTIME_ROOT}/data/tmp"
  tool_data_path: "${GALAXY_TOOL_DATA_PATH}"
  job_working_directory: "${GALAXY_RUNTIME_ROOT}/data/job_working_directory"
  tool_dependency_dir: "${GALAXY_RUNTIME_ROOT}/data/tool_dependencies"
  tool_config_file: "${GALAXY_TOOL_CONFIG_FILE}"
  shed_tool_config_file: "${GALAXY_SHED_TOOL_CONFIG_FILE}"
  shed_tool_path: "${GALAXY_SHED_TOOL_PATH}"
  tool_sheds_config_file: "${GALAXY_TOOL_SHEDS_CONFIG_FILE}"
  file_sources_config_file: "${GALAXY_FILE_SOURCES_CONFIG_FILE}"
  user_library_import_dir: "${GALAXY_USER_LIBRARY_IMPORT_DIR}"
  allow_path_paste: ${GALAXY_ALLOW_PATH_PASTE}
  dependency_resolvers_config_file: "${GALAXY_DEPENDENCY_RESOLVERS_CONFIG_FILE}"
  conda_prefix: "${GALAXY_CONDA_PREFIX}"
  conda_auto_init: ${GALAXY_CONDA_AUTO_INIT}
  conda_auto_install: ${GALAXY_CONDA_AUTO_INSTALL}
  conda_exec: "${GALAXY_CONDA_EXEC}"
EOF_INNER

if [ -n "$GALAXY_SMTP_SERVER" ]; then
    cat >>"$GALAXY_CONFIG_FILE" <<EOF_INNER
  smtp_server: "${GALAXY_SMTP_SERVER}"
EOF_INNER
fi

if [ -n "$GALAXY_SMTP_USERNAME" ]; then
    cat >>"$GALAXY_CONFIG_FILE" <<EOF_INNER
  smtp_username: "${GALAXY_SMTP_USERNAME}"
EOF_INNER
fi

if [ -n "$GALAXY_SMTP_PASSWORD" ]; then
    cat >>"$GALAXY_CONFIG_FILE" <<EOF_INNER
  smtp_password: "${GALAXY_SMTP_PASSWORD}"
EOF_INNER
fi

cat >>"$GALAXY_CONFIG_FILE" <<EOF_INNER
  smtp_ssl: ${GALAXY_SMTP_SSL}
EOF_INNER

if [ -n "$GALAXY_EMAIL_FROM" ]; then
    cat >>"$GALAXY_CONFIG_FILE" <<EOF_INNER
  email_from: "${GALAXY_EMAIL_FROM}"
EOF_INNER
fi

if [ -n "$GALAXY_ERROR_EMAIL_TO" ]; then
    cat >>"$GALAXY_CONFIG_FILE" <<EOF_INNER
  error_email_to: "${GALAXY_ERROR_EMAIL_TO}"
EOF_INNER
fi

cat >>"$GALAXY_CONFIG_FILE" <<EOF_INNER
gravity:
  galaxy_root: "${GALAXY_ROOT_DIR}"
  virtualenv: "${GALAXY_VIRTUAL_ENV}"
  log_dir: "${GALAXY_GRAVITY_STATE_DIR}/log"
  app_server: "gunicorn"
  gunicorn:
    bind: "${GALAXY_CONFIG_HOST}:${GALAXY_CONFIG_PORT}"
EOF_INNER

cd "$GALAXY_ROOT"
exec sh run.sh --skip-samples --skip-client-build "$@"
EOF
chmod 0755 "${START_GALAXY_SCRIPT}"

export GALAXY_CONFIG_HOST="0.0.0.0"
export GALAXY_CONFIG_PORT="${port}"
export GALAXY_URL_PREFIX="/node/${host}/${port}"
export GALAXY_RUNTIME_ROOT="/tmp/galaxy"
export GALAXY_LOG_DIR="/tmp/galaxy/log"
export GALAXY_PID_DIR="/tmp/galaxy/pids"
export GALAXY_SLOTS="<%= context.num_cores.to_s.strip %>"
export GALAXY_MEMORY_MB="${GALAXY_MEMORY_MB}"
export GALAXY_CONFIG_FILE="/tmp/galaxy/config/galaxy.yml"
export GALAXY_JOB_CONFIG_FILE="/tmp/galaxy/config/job_conf.xml"
export GALAXY_TOOL_CONFIG_FILE="/srv/galaxy/config/tool_conf.xml,/opt/galaxy/config/tool_conf.xml.sample"
export GALAXY_SHED_TOOL_CONFIG_FILE="/srv/galaxy/config/shed_tool_conf.xml"
export GALAXY_SHED_TOOL_PATH="/srv/galaxy/shed_tools"
export GALAXY_TOOL_DATA_PATH="/srv/galaxy/tool-data"
export GALAXY_FILE_SOURCES_CONFIG_FILE="/tmp/galaxy/config/file_sources_conf.yml"
export GALAXY_USER_LIBRARY_IMPORT_DIR="${HOST_HOME}"
export GALAXY_ALLOW_PATH_PASTE="true"
export GALAXY_TOOL_SHEDS_CONFIG_FILE="/srv/galaxy/config/tool_sheds_conf.xml"
export GALAXY_DEPENDENCY_RESOLVERS_CONFIG_FILE="/srv/galaxy/config/dependency_resolvers_conf.xml"
export GALAXY_CONDA_PREFIX="/srv/galaxy/conda"
export GALAXY_CONDA_AUTO_INIT="true"
export GALAXY_CONDA_AUTO_INSTALL="false"
export GALAXY_CONDA_EXEC="${ANACONDA_ROOT}/bin/conda"
export GALAXY_ADMIN_USERS="david.carlson@stonybrook.edu"
export GALAXY_SMTP_SERVER="${GALAXY_SMTP_SERVER:-}"
export GALAXY_SMTP_USERNAME="${GALAXY_SMTP_USERNAME:-}"
export GALAXY_SMTP_PASSWORD="${GALAXY_SMTP_PASSWORD:-}"
export GALAXY_SMTP_SSL="${GALAXY_SMTP_SSL:-false}"
export GALAXY_EMAIL_FROM="${GALAXY_EMAIL_FROM:-}"
export GALAXY_ERROR_EMAIL_TO="${GALAXY_ERROR_EMAIL_TO:-}"
export CONDA_ENVS_PATH="/srv/galaxy/conda/envs"
export CONDA_PKGS_DIRS="/srv/galaxy/conda/pkgs"
export TMPDIR="${GALAXY_TMPDIR}"
export GALAXY_SKIP_CLIENT_BUILD="1"
export GIT_CONFIG_COUNT="1"
export GIT_CONFIG_KEY_0="safe.directory"
export GIT_CONFIG_VALUE_0="/opt/galaxy"

for path in \
  "${SHARED_GALAXY_CONDA_ROOT}/envs" \
  "${SHARED_GALAXY_CONDA_ROOT}/pkgs" \
  "${SHARED_GALAXY_CONDA_ROOT}/bin/activate"; do
  if [[ ! -e "${path}" ]]; then
    echo "Shared Galaxy conda path is missing: ${path}" >&2
    echo "Populate ${SHARED_GALAXY_CONDA_ROOT} as an admin before exposing this app cluster-wide." >&2
    exit 1
  fi
done

case "${GALAXY_FILE_SOURCE_SELECTION}" in
  home_scratch)
    export GALAXY_ENABLE_SCRATCH_FILE_SOURCE="true"
    export GALAXY_ENABLE_PROJECTS_FILE_SOURCE="false"
    ;;
  home_projects)
    export GALAXY_ENABLE_SCRATCH_FILE_SOURCE="false"
    export GALAXY_ENABLE_PROJECTS_FILE_SOURCE="true"
    ;;
  home_scratch_projects)
    export GALAXY_ENABLE_SCRATCH_FILE_SOURCE="true"
    export GALAXY_ENABLE_PROJECTS_FILE_SOURCE="true"
    ;;
  *)
    export GALAXY_ENABLE_SCRATCH_FILE_SOURCE="false"
    export GALAXY_ENABLE_PROJECTS_FILE_SOURCE="false"
    ;;
esac

for var in \
  GALAXY_CONFIG_HOST \
  GALAXY_CONFIG_PORT \
  GALAXY_URL_PREFIX \
  GALAXY_RUNTIME_ROOT \
  GALAXY_LOG_DIR \
  GALAXY_PID_DIR \
  GALAXY_SLOTS \
  GALAXY_MEMORY_MB \
  GALAXY_CONFIG_FILE \
  GALAXY_JOB_CONFIG_FILE \
  GALAXY_TOOL_CONFIG_FILE \
  GALAXY_SHED_TOOL_CONFIG_FILE \
  GALAXY_SHED_TOOL_PATH \
  GALAXY_TOOL_DATA_PATH \
  GALAXY_FILE_SOURCES_CONFIG_FILE \
  GALAXY_USER_LIBRARY_IMPORT_DIR \
  GALAXY_ALLOW_PATH_PASTE \
  GALAXY_TOOL_SHEDS_CONFIG_FILE \
  GALAXY_DEPENDENCY_RESOLVERS_CONFIG_FILE \
  GALAXY_CONDA_PREFIX \
  GALAXY_CONDA_AUTO_INIT \
  GALAXY_CONDA_AUTO_INSTALL \
  GALAXY_CONDA_EXEC \
  GALAXY_ADMIN_USERS \
  GALAXY_SMTP_SERVER \
  GALAXY_SMTP_USERNAME \
  GALAXY_SMTP_PASSWORD \
  GALAXY_SMTP_SSL \
  GALAXY_EMAIL_FROM \
  GALAXY_ERROR_EMAIL_TO \
  CONDA_ENVS_PATH \
  CONDA_PKGS_DIRS \
  TMPDIR \
  GALAXY_ENABLE_SCRATCH_FILE_SOURCE \
  GALAXY_ENABLE_PROJECTS_FILE_SOURCE \
  GALAXY_SKIP_CLIENT_BUILD \
  GIT_CONFIG_COUNT \
  GIT_CONFIG_KEY_0 \
  GIT_CONFIG_VALUE_0; do
  export "SINGULARITYENV_${var}=${!var}"
  export "APPTAINERENV_${var}=${!var}"
done

BIND_ARGS+=("--bind" "${GALAXY_HOST_ROOT}:/tmp/galaxy")
BIND_ARGS+=("--bind" "${HOST_HOME}:${HOST_HOME}")
BIND_ARGS+=("--bind" "/gpfs:/gpfs")
BIND_ARGS+=("--bind" "${START_GALAXY_SCRIPT}:/usr/local/bin/start-galaxy")
BIND_ARGS+=("--bind" "${SHARED_GALAXY_CONFIG_ROOT}:/srv/galaxy/config")
BIND_ARGS+=("--bind" "${SHARED_GALAXY_TOOLS_ROOT}:/srv/galaxy/tools")
BIND_ARGS+=("--bind" "${SHARED_GALAXY_SHED_TOOLS_ROOT}:/srv/galaxy/shed_tools")
BIND_ARGS+=("--bind" "${SHARED_GALAXY_TOOL_DATA_ROOT}:/srv/galaxy/tool-data")
BIND_ARGS+=("--bind" "${SHARED_GALAXY_CONDA_ROOT}:/srv/galaxy/conda")
BIND_ARGS+=("--bind" "${ANACONDA_ROOT}:${ANACONDA_ROOT}")

echo "$(date): Running Galaxy on compute node $(hostname):${port}"
echo "$(date): Using ${container_runtime} image ${IMAGE}"
echo "$(date): Galaxy writable state is ${GALAXY_HOST_ROOT}"
echo "$(date): Shared Galaxy config is ${SHARED_GALAXY_CONFIG_ROOT}"
echo "$(date): Shared Galaxy tools are ${SHARED_GALAXY_TOOLS_ROOT}"
echo "$(date): Shared Galaxy shed tools are ${SHARED_GALAXY_SHED_TOOLS_ROOT}"
echo "$(date): Shared Galaxy tool-data is ${SHARED_GALAXY_TOOL_DATA_ROOT}"
echo "$(date): Shared Galaxy conda is ${SHARED_GALAXY_CONDA_ROOT}"
echo "$(date): Galaxy conda executable is ${GALAXY_CONDA_EXEC}"

cd "${HOME}"
set -x
"${container_runtime}" run \
  "${BIND_ARGS[@]}" \
  "${IMAGE}"
